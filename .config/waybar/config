{
    // в”Ђв”Ђв”Ђ Bar Layout в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 0,
    "margin": 3,


    "modules-left":   ["hyprland/workspaces", "hyprland/submap"],
    "modules-center": ["clock"],
    "modules-right":  ["tray", "custom/swaync", "pulseaudio", "network", "cpu", "memory", "battery"],


    // в”Ђв”Ђв”Ђ Left в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        // Show workspace number; urgent ones get a dot indicator via CSS
        "format": "{name}",
        "format-icons": {
            "urgent":  "у°ќ¦",
            "active":  "у°ќҐ",   // Hyprland uses "active" (not "focused")
            "default": "у°ќЈ"
        }
    },

    "hyprland/submap": {                          // Hyprland equivalent of sway/mode
        "format": "  {}"
    },


    // в”Ђв”Ђв”Ђ Center в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    "clock": {
        // 24h time  В·  day of month  (e.g. "14:35  В·  19")
        "format": "{:%H:%M  В·  %d}",
        "format-alt": "{:%A, %d %B %Y  В·  %H:%M:%S}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "interval": 1
    },


    // в”Ђв”Ђв”Ђ Right в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    "tray": {
        "icon-size": 14,
        "spacing": 6
    },

    "pulseaudio": {
        // :3 pads volume to 3 chars вЂ” same structure muted/unmuted = no width shift
        "format": "{icon} {volume}%",
        "format-muted": "у°ќџ {volume}%",
        "format-icons": {
            "default": ["у°•ї", "у°–Ђ", "у°•ѕ"]
        },
        "scroll-step": 2,
        "on-click": "pavucontrol",
        "tooltip": false
    },

    "network": {
        "interval": 5,
        "format-wifi":         "у°¤Ё {essid} ({signalStrength}%)",
        "format-ethernet":     "у°€Ђ {ifname}",
        "format-disconnected": "у°¤­ No connection",
        // Shows IPv4 on hover
        "tooltip-format": "у°©   {ipaddr}\nу°€Ђ  {ifname}\n  {bandwidthUpBytes}  /  у°‡љ {bandwidthDownBytes}"
    },

    // в”Ђв”Ђв”Ђ Hardware group: CPU + RAM share one pill в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    "group/hardware": {
        "orientation": "horizontal",
        "modules": ["cpu", "memory"]
    },

    "cpu": {
        "interval": 2,
        // :2 pads to 2 chars вЂ” stable width from 1% to 99%
        "format": "\uf4bc{usage:2}% ",
        "tooltip": true,
        "format-tooltip": "Core breakdown:\n{core0}% В· {core1}% В· {core2}% В· {core3}%"
    },

    "memory": {
        "interval": 5,
        // 4.1f pads to 4 chars before G вЂ” stable up to 99.9G
        "format": "\uefc5{used:4.1f}G",
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G"
    },

    // в”Ђв”Ђв”Ђ swaync notification bell в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // {} = unread count (hidden when 0 via format-icons "none" key)
    // Right-click toggles Do Not Disturb
    "custom/swaync": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification":               "у±…«",
            "none":                       "у°‚љ",
            "dnd-notification":           "у°Є“",
            "dnd-none":                   "у°‚›",
            "inhibited-notification":     "у±…«",
            "inhibited-none":             "у°‚љ",
            "dnd-inhibited-notification": "у°Є“",
            "dnd-inhibited-none":         "у°‚›"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    // в”Ђв”Ђв”Ђ Battery: standalone pill в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    "battery": {
        "interval": 30,
        // Discharging: icon + %
        "format": "{icon} {capacity}%",
        // Charging: arrow up  + %
        "format-charging": "у°‚„ {capacity}%  в†‘",
        // Plugged in at full / wall power: plug icon
        "format-plugged":  "у±џў {capacity}%",
        // 10-step icons for smooth visual drain feedback
        "format-icons": ["у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚", "у°Ѓ№"],
        "states": {
            "full":     100,
            "good":      95,
            "warning":   30,
            "critical":  15
        },
        "tooltip-format": "{timeTo}\n{power}W"
    }
}
